{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": {
		"includes": ["**"]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"indentStyle": "space",
		"indentWidth": 2
	},
	"linter": {
		"enabled": false
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"trailingCommas": "es5"
		}
	}
}
