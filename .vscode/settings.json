  "files.associations": {
    "secrets*": "properties",
    "gitconfig*": "properties",
    "zshrc*": "shellscript",
    "ohmyzsh*": "shellscript",
    "p10k*": "shellscript",
    "gitignore_global*": "gitignore",
    "": "shellscript",
