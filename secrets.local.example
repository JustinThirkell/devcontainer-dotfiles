# These secrets should NOT go in this repo.
# Instead, forward them from your host machine via remoteEnv in your
# Cursor/VS Code user settings.json:
#
#   "remoteEnv": {
#     "CLICKUP_API_KEY": "${localEnv:CLICKUP_API_KEY}",
#     "GH_TOKEN": "${localEnv:GH_TOKEN}"
#   }
#
# On your host machine, set these in ~/.secrets.local or your shell profile.

export CLICKUP_API_KEY="your-clickup-api-key"
export GH_TOKEN="your-github-token"
